generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

//
// ENUMS
//

enum UserStatus {
  ACTIVE
  DISABLED
}

enum AuthProvider {
  LOCAL
}

enum InventoryMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum InventorySourceType {
  PRODUCTION
  ORDER
  MANUAL
  TRANSFER
  RETURN
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  PROCESSING
  DISPATCHED
  COMPLETED
  SHIPPED
  DELIVERED
  CANCELLED
  CLOSED
}

enum InvoiceStatus {
  DRAFT
  PENDING
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}

enum InvoiceKind {
  PROFORMA
  TAX_INVOICE
  CREDIT_NOTE
  DEBIT_NOTE
}

enum PurchaseStatus {
  DRAFT
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
  CLOSED
}

enum PaymentStatus {
  RECORDED
  REVERSED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  UPI
  CHEQUE
  CARD
  OTHER
}

enum MessageChannel {
  EMAIL
  WHATSAPP
}

enum DispatchJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
}

enum ChargeType {
  TAX
  SHIPPING
  DISCOUNT
  OTHER
}

enum GstRegistrationType {
  REGISTERED
  UNREGISTERED
  COMPOSITION
  EXPORT
  SEZ
  EXEMPT
}

enum GstSupplyType {
  INTRA_STATE
  INTER_STATE
  EXPORT
}

enum ProductTrackingMode {
  NONE
  BARCODE_ONLY
  SERIAL_ONLY
  BATCH_ONLY
  BATCH_EXPIRY
  SERIAL_BATCH
  SERIAL_BATCH_EXPIRY
}

enum SerialStatus {
  IN_STOCK
  RESERVED
  DISPATCHED
  RETURNED
  SCRAPPED
}

enum PurchaseReceiptStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum SupplierReturnStatus {
  DRAFT
  APPROVED
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum DeliveryChallanStatus {
  DRAFT
  ISSUED
  CLOSED
  CANCELLED
}

enum DeliveryChallanKind {
  OUTWARD
  INWARD
  JOB_WORK
  RETURNABLE
  NON_RETURNABLE
}

enum DeliveryChallanReason {
  SALE
  RETURN
  JOB_WORK
  SAMPLE
  OTHER
}

//
// BASE / TENANT
//

model Company {
  id                    String               @id @default(cuid())
  name                  String
  legal_name            String?
  gstin                 String?
  gst_registration_type GstRegistrationType?
  phone                 String?
  email                 String?
  address               String?
  state                 String?
  state_code            String?
  is_gst_enabled        Boolean              @default(true)
  is_active             Boolean              @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  factories   Factory[]
  users       User[]
  roles       Role[]
  permissions Permission[]

  // Company-level catalog & CRM
  product_categories           ProductCategory[]
  products                     Product[]
  clients                      Client[]
  tax_classes                  TaxClass[]
  product_barcodes             ProductBarcode[]
  inventory_batches            InventoryBatch[]
  inventory_serials            InventorySerial[]
  inventory_tracking_balances  InventoryTrackingBalance[]
  inventory_movement_trackings InventoryMovementTracking[]
  delivery_challans            DeliveryChallan[]
  delivery_challan_items       DeliveryChallanItem[]
  purchase_receipts            PurchaseReceipt[]
  purchase_receipt_items       PurchaseReceiptItem[]
  supplier_returns             SupplierReturn[]
  supplier_return_items        SupplierReturnItem[]
  compliance_reports           ComplianceReport[]
  UserSession                  UserSession[]
  password_reset_otps          PasswordResetOtp[]
  UserRoleMap                  UserRoleMap[]
  RolePermissionMap            RolePermissionMap[]
  UserPermissionMap            UserPermissionMap[]
  UserFactoryMap               UserFactoryMap[]
  ActivityLog                  ActivityLog[]
  ClientContact                ClientContact[]
  ClientProduct                ClientProduct[]
  ProductionLog                ProductionLog[]
  InventoryMovement            InventoryMovement[]
  StockSnapshot                StockSnapshot[]
  stock_balances               StockBalance[]
  number_sequences             NumberSequence[]
  Order                        Order[]
  OrderItem                    OrderItem[]
  OrderCharge                  OrderCharge[]
  OrderStatusHistory           OrderStatusHistory[]
  OrderFulfillment             OrderFulfillment[]
  Invoice                      Invoice[]
  InvoiceItem                  InvoiceItem[]
  InvoiceCharge                InvoiceCharge[]
  InvoiceStatusHistory         InvoiceStatusHistory[]
  Payment                      Payment[]
  PaymentAllocation            PaymentAllocation[]
  Purchase                     Purchase[]
  PurchaseItem                 PurchaseItem[]
  PurchaseCharge               PurchaseCharge[]
  PurchaseStatusHistory        PurchaseStatusHistory[]
  MessageTemplate              MessageTemplate[]
  MessageCampaign              MessageCampaign[]
  MessageRecipient             MessageRecipient[]
  MessageLog                   MessageLog[]
  message_dispatch_jobs        MessageDispatchJob[]

  // Legal entities used for sales (billing company selection on orders/invoices/payments)
  sales_companies SalesCompany[]
  platform_config CompanyPlatformConfig?

  // Internal realtime chat + announcements
  conversations        Conversation[]
  conversation_members ConversationMember[]
  chat_messages        ChatMessage[]
  broadcast_messages   BroadcastMessage[]
  broadcast_recipients BroadcastRecipient[]

  @@index([is_active])
}

// Sales / billing companies within a tenant.
// Example: one tenant may operate multiple legal entities for invoicing.
model SalesCompany {
  id         String @id @default(cuid())
  company_id String

  name                  String
  legal_name            String?
  gstin                 String?
  gst_registration_type GstRegistrationType?
  phone                 String?
  email                 String?
  address               String?
  state                 String?
  state_code            String?
  is_gst_enabled        Boolean?
  is_active             Boolean              @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company Company @relation(fields: [company_id], references: [id])

  orders            Order[]
  invoices          Invoice[]
  payments          Payment[]
  delivery_challans DeliveryChallan[]

  @@unique([company_id, name])
  @@index([company_id, is_active])
}

model Factory {
  id         String  @id @default(cuid())
  company_id String
  name       String
  code       String?
  address    String?
  state      String?
  state_code String?
  is_active  Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company Company @relation(fields: [company_id], references: [id])

  // Factory-scoped operational data
  production_logs              ProductionLog[]
  inventory_movements          InventoryMovement[]
  inventory_movement_trackings InventoryMovementTracking[]
  stock_snapshots              StockSnapshot[]
  stock_balances               StockBalance[]
  inventory_batches            InventoryBatch[]
  inventory_serials            InventorySerial[]
  inventory_tracking_balances  InventoryTrackingBalance[]
  orders                       Order[]
  order_fulfillments           OrderFulfillment[]
  invoices                     Invoice[]
  purchases                    Purchase[]
  payments                     Payment[]
  delivery_challans            DeliveryChallan[]
  purchase_receipts            PurchaseReceipt[]
  supplier_returns             SupplierReturn[]

  user_factory_map UserFactoryMap[]

  @@unique([company_id, name])
  @@index([company_id, is_active])
}

//
// AUTH / RBAC
//

model User {
  id            String       @id @default(cuid())
  company_id    String
  email         String       @unique
  phone         String?
  name          String
  password_hash String
  provider      AuthProvider @default(LOCAL)

  status   UserStatus @default(ACTIVE)
  is_admin Boolean    @default(false)

  last_login_at DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  company Company @relation(fields: [company_id], references: [id])

  roles_map           UserRoleMap[]
  permissions_map     UserPermissionMap[]
  factories_map       UserFactoryMap[]
  sessions            UserSession[]
  password_reset_otps PasswordResetOtp[]
  activity_logs       ActivityLog[]

  // Internal realtime chat + announcements
  conversation_members ConversationMember[]
  chat_messages_sent   ChatMessage[]        @relation("ChatMessageSender")
  broadcasts_sent      BroadcastMessage[]   @relation("BroadcastSender")
  broadcast_recipients BroadcastRecipient[]

  @@index([company_id, status])
  @@index([company_id, is_admin])
}

model UserSession {
  id           String    @id @default(cuid())
  company_id   String
  user_id      String
  token_jti    String    @unique
  ip           String?
  user_agent   String?
  last_seen_at DateTime  @default(now())
  expires_at   DateTime
  revoked_at   DateTime?

  created_at DateTime @default(now())

  company Company @relation(fields: [company_id], references: [id])
  user    User    @relation(fields: [user_id], references: [id])

  @@index([company_id, user_id])
  @@index([company_id, revoked_at, expires_at])
}

model PasswordResetOtp {
  id         String @id @default(cuid())
  company_id String
  user_id    String
  email      String

  otp_hash      String
  attempt_count Int       @default(0)
  expires_at    DateTime
  used_at       DateTime?

  requested_ip         String?
  requested_user_agent String?

  created_at DateTime @default(now())

  company Company @relation(fields: [company_id], references: [id])
  user    User    @relation(fields: [user_id], references: [id])

  @@index([company_id, user_id, expires_at])
  @@index([user_id, used_at, expires_at])
  @@index([company_id, email, created_at])
}

model Role {
  id          String  @id @default(cuid())
  company_id  String
  name        String
  description String?
  is_system   Boolean @default(false)
  is_active   Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company Company @relation(fields: [company_id], references: [id])

  user_map         UserRoleMap[]
  role_permissions RolePermissionMap[]

  @@unique([company_id, name])
  @@index([company_id, is_active])
}

model Permission {
  id          String  @id @default(cuid())
  company_id  String
  key         String
  description String?
  is_active   Boolean @default(true)

  created_at DateTime @default(now())

  company  Company             @relation(fields: [company_id], references: [id])
  role_map RolePermissionMap[]
  user_map UserPermissionMap[]

  @@unique([company_id, key])
  @@index([company_id, is_active])
}

model UserRoleMap {
  id         String @id @default(cuid())
  company_id String
  user_id    String
  role_id    String

  created_at DateTime @default(now())
  created_by String?

  user    User    @relation(fields: [user_id], references: [id])
  role    Role    @relation(fields: [role_id], references: [id])
  company Company @relation(fields: [company_id], references: [id])

  @@unique([company_id, user_id, role_id])
  @@index([company_id, user_id])
}

model RolePermissionMap {
  id            String @id @default(cuid())
  company_id    String
  role_id       String
  permission_id String

  created_at DateTime @default(now())
  created_by String?

  company    Company    @relation(fields: [company_id], references: [id])
  role       Role       @relation(fields: [role_id], references: [id])
  permission Permission @relation(fields: [permission_id], references: [id])

  @@unique([company_id, role_id, permission_id])
  @@index([company_id, role_id])
}

// Allows admin to grant/revoke specific permissions directly to a user
// in addition to role-based permissions.
model UserPermissionMap {
  id            String @id @default(cuid())
  company_id    String
  user_id       String
  permission_id String

  created_at DateTime @default(now())
  created_by String?

  company    Company    @relation(fields: [company_id], references: [id])
  user       User       @relation(fields: [user_id], references: [id])
  permission Permission @relation(fields: [permission_id], references: [id])

  @@unique([company_id, user_id, permission_id])
  @@index([company_id, user_id])
}

model UserFactoryMap {
  id         String @id @default(cuid())
  company_id String
  user_id    String
  factory_id String

  created_at DateTime @default(now())
  created_by String?

  user    User    @relation(fields: [user_id], references: [id])
  factory Factory @relation(fields: [factory_id], references: [id])
  company Company @relation(fields: [company_id], references: [id])

  @@unique([company_id, user_id, factory_id])
  @@index([company_id, factory_id])
}

//
model NumberSequence {
  id         String @id @default(cuid())
  company_id String
  key        String
  last_value Int    @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company Company @relation(fields: [company_id], references: [id])

  @@unique([company_id, key])
  @@index([company_id, updated_at])
}

// AUDIT
//

model ActivityLog {
  id         String  @id @default(cuid())
  company_id String
  factory_id String?

  user_id     String?
  action      String
  entity_type String?
  entity_id   String?
  meta        Json?

  ip         String?
  user_agent String?

  created_at DateTime @default(now())

  company Company @relation(fields: [company_id], references: [id])
  user    User?   @relation(fields: [user_id], references: [id])

  @@index([company_id, factory_id, created_at])
  @@index([company_id, user_id, created_at])
}

//
// PRODUCT CATALOG (company-level)
//

model ProductCategory {
  id          String  @id @default(cuid())
  company_id  String
  name        String
  description String?
  is_active   Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company  Company   @relation(fields: [company_id], references: [id])
  products Product[]

  @@unique([company_id, name])
  @@index([company_id, is_active])
}

model Product {
  id              String              @id @default(cuid())
  company_id      String
  category_id     String
  tax_class_id    String?
  name            String
  sku             String?
  unit            String // e.g. KG, PCS, SACK, PACK
  pack_size       String? // e.g. "25kg sack", "200g pouch" (variant-like)
  price           Decimal             @default(0) @db.Decimal(15, 2) // selling price (default 0)
  hsn_sac_code    String?
  gst_rate        Decimal?            @db.Decimal(5, 2)
  cess_rate       Decimal?            @db.Decimal(5, 2)
  tracking_mode   ProductTrackingMode @default(NONE)
  shelf_life_days Int?
  description     String?
  is_active       Boolean             @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company   Company         @relation(fields: [company_id], references: [id])
  category  ProductCategory @relation(fields: [category_id], references: [id])
  tax_class TaxClass?       @relation(fields: [tax_class_id], references: [id])

  // links
  client_products              ClientProduct[]
  production_logs              ProductionLog[]
  inventory_movements          InventoryMovement[]
  inventory_batches            InventoryBatch[]
  inventory_serials            InventorySerial[]
  product_barcodes             ProductBarcode[]
  inventory_tracking_balances  InventoryTrackingBalance[]
  inventory_movement_trackings InventoryMovementTracking[]
  order_items                  OrderItem[]
  order_fulfillments           OrderFulfillment[]
  invoice_items                InvoiceItem[]
  purchase_items               PurchaseItem[]
  delivery_challan_items       DeliveryChallanItem[]
  purchase_receipt_items       PurchaseReceiptItem[]
  supplier_return_items        SupplierReturnItem[]
  StockSnapshot                StockSnapshot[]
  stock_balances               StockBalance[]

  @@unique([company_id, name, pack_size])
  @@index([company_id, category_id, is_active])
  @@index([company_id, is_active, updated_at])
  @@index([company_id, tracking_mode])
}

//
// CLIENTS (company-level, visible across all factories)
//

model Client {
  id         String @id @default(cuid())
  company_id String

  company_name          String
  gstin                 String?
  gst_registration_type GstRegistrationType?
  phone                 String?
  email                 String?
  address               String?
  city                  String?
  state                 String?
  state_code            String?
  pincode               String?

  is_active Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company           Company           @relation(fields: [company_id], references: [id])
  contacts          ClientContact[]
  products          ClientProduct[]
  orders            Order[]
  invoices          Invoice[]
  Payment           Payment[]
  delivery_challans DeliveryChallan[]

  @@unique([company_id, company_name])
  @@index([company_id, is_active])
  @@index([company_id, is_active, updated_at])
}

model ClientContact {
  id         String @id @default(cuid())
  company_id String
  client_id  String

  name        String
  designation String?
  phone       String?
  email       String?
  address     String?

  is_active Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company Company @relation(fields: [company_id], references: [id])
  client  Client  @relation(fields: [client_id], references: [id])

  @@index([company_id, client_id, is_active])
}

model ClientProduct {
  id         String @id @default(cuid())
  company_id String
  client_id  String
  product_id String

  // Optional: per-client default pricing / terms
  default_price Decimal? @db.Decimal(15, 2)
  notes         String?
  is_active     Boolean  @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company Company @relation(fields: [company_id], references: [id])
  client  Client  @relation(fields: [client_id], references: [id])
  product Product @relation(fields: [product_id], references: [id])

  @@unique([company_id, client_id, product_id])
  @@index([company_id, product_id])
}

//
// PRODUCTION (factory-scoped)
//

model ProductionLog {
  id         String @id @default(cuid())
  company_id String
  factory_id String
  product_id String

  date     DateTime // production date (store date as DateTime for flexibility)
  quantity Decimal  @db.Decimal(15, 2)
  remarks  String?

  created_by String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  company Company @relation(fields: [company_id], references: [id])
  factory Factory @relation(fields: [factory_id], references: [id])
  product Product @relation(fields: [product_id], references: [id])

  @@index([company_id, factory_id, date])
  @@index([company_id, factory_id, product_id, date])
}

//
// INVENTORY (append-only movements; stock is derived)
//

model InventoryMovement {
  id         String @id @default(cuid())
  company_id String
  factory_id String
  product_id String

  type        InventoryMovementType
  source_type InventorySourceType
  source_id   String? // link to ProductionLog / Order / Return etc.

  date      DateTime @default(now())
  quantity  Decimal  @db.Decimal(15, 2)
  unit_cost Decimal? @db.Decimal(15, 2)

  remarks String?

  created_by String?
  created_at DateTime @default(now())

  company Company @relation(fields: [company_id], references: [id])
  factory Factory @relation(fields: [factory_id], references: [id])
  product Product @relation(fields: [product_id], references: [id])

  tracking_lines InventoryMovementTracking[]

  @@index([company_id, factory_id, date])
  @@index([company_id, factory_id, product_id, date])
  @@index([company_id, source_type, source_id])
}

// Optional performance helper (not required; can be built later)
// Stores end-of-day stock so monthly/yearly inventory screens are faster.
model StockSnapshot {
  id         String @id @default(cuid())
  company_id String
  factory_id String
  product_id String

  as_of_date DateTime // typically end of day
  quantity   Decimal  @db.Decimal(15, 2)

  created_at DateTime @default(now())

  company Company @relation(fields: [company_id], references: [id])
  factory Factory @relation(fields: [factory_id], references: [id])
  product Product @relation(fields: [product_id], references: [id])

  @@unique([company_id, factory_id, product_id, as_of_date])
  @@index([company_id, factory_id, as_of_date])
}

//
model StockBalance {
  id         String @id @default(cuid())
  company_id String
  factory_id String
  product_id String

  quantity Decimal @default(0) @db.Decimal(15, 2)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company Company @relation(fields: [company_id], references: [id])
  factory Factory @relation(fields: [factory_id], references: [id])
  product Product @relation(fields: [product_id], references: [id])

  @@unique([company_id, factory_id, product_id])
  @@index([company_id, factory_id, updated_at])
  @@index([company_id, product_id])
}

// ORDERS (factory-scoped; linked to global Client & catalog)
//

model Order {
  id         String @id @default(cuid())
  company_id String
  factory_id String
  client_id  String

  // Billing / legal entity used for this sale
  sales_company_id String?

  // Optional logistics partner name
  logistics String?

  order_no String
  status   OrderStatus @default(DRAFT)

  order_date   DateTime  @default(now())
  required_by  DateTime?
  delivered_at DateTime?

  place_of_supply_state String?
  place_of_supply_code  String?
  supply_type           GstSupplyType?
  is_gst_invoice        Boolean        @default(true)

  // Summary fields (can be derived, but storing helps listing)
  subtotal      Decimal @default(0) @db.Decimal(15, 2)
  tax_subtotal  Decimal @default(0) @db.Decimal(15, 2)
  total_charges Decimal @default(0) @db.Decimal(15, 2)
  cgst_total    Decimal @default(0) @db.Decimal(15, 2)
  sgst_total    Decimal @default(0) @db.Decimal(15, 2)
  igst_total    Decimal @default(0) @db.Decimal(15, 2)
  cess_total    Decimal @default(0) @db.Decimal(15, 2)
  round_off     Decimal @default(0) @db.Decimal(15, 2)
  total         Decimal @default(0) @db.Decimal(15, 2)
  gst_breakup   Json?

  notes          String?
  internal_notes String?

  is_active Boolean @default(true) // soft delete (archived)

  created_by String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company       Company       @relation(fields: [company_id], references: [id])
  factory       Factory       @relation(fields: [factory_id], references: [id])
  client        Client        @relation(fields: [client_id], references: [id])
  sales_company SalesCompany? @relation(fields: [sales_company_id], references: [id])

  items             OrderItem[]
  charges           OrderCharge[]
  status_history    OrderStatusHistory[]
  invoices          Invoice[]
  payments          Payment[]
  fulfillments      OrderFulfillment[]
  delivery_challans DeliveryChallan[]

  @@unique([company_id, order_no])
  @@index([company_id, factory_id, order_date])
  @@index([company_id, factory_id, client_id, order_date])
  @@index([company_id, status])
  @@index([company_id, is_active, order_date])
  @@index([company_id, is_active, status, order_date])
  @@index([company_id, sales_company_id])
}

model OrderItem {
  id         String @id @default(cuid())
  company_id String
  order_id   String
  product_id String

  quantity      Decimal  @db.Decimal(15, 2)
  unit_price    Decimal  @db.Decimal(15, 2)
  discount      Decimal? @db.Decimal(15, 2) // item-level discount
  line_total    Decimal  @db.Decimal(15, 2)
  hsn_sac_code  String?
  gst_rate      Decimal? @db.Decimal(5, 2)
  cgst_rate     Decimal? @db.Decimal(5, 2)
  sgst_rate     Decimal? @db.Decimal(5, 2)
  igst_rate     Decimal? @db.Decimal(5, 2)
  cess_rate     Decimal? @db.Decimal(5, 2)
  taxable_value Decimal? @db.Decimal(15, 2)
  tax_amount    Decimal? @db.Decimal(15, 2)
  cgst_amount   Decimal? @db.Decimal(15, 2)
  sgst_amount   Decimal? @db.Decimal(15, 2)
  igst_amount   Decimal? @db.Decimal(15, 2)
  cess_amount   Decimal? @db.Decimal(15, 2)

  remarks String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  order   Order   @relation(fields: [order_id], references: [id])
  product Product @relation(fields: [product_id], references: [id])
  company Company @relation(fields: [company_id], references: [id])

  @@index([company_id, order_id])
  @@index([company_id, product_id])
}

model OrderCharge {
  id         String @id @default(cuid())
  company_id String
  order_id   String

  type   ChargeType
  title  String // "GST 5%", "Shipping", "Packing", "Custom Charge"
  amount Decimal    @db.Decimal(15, 2)
  meta   Json?

  created_at DateTime @default(now())

  order   Order   @relation(fields: [order_id], references: [id])
  company Company @relation(fields: [company_id], references: [id])

  @@index([company_id, order_id])
}

model OrderStatusHistory {
  id         String      @id @default(cuid())
  company_id String
  order_id   String
  status     OrderStatus
  note       String?
  meta       Json?

  created_by String?
  created_at DateTime @default(now())

  order   Order   @relation(fields: [order_id], references: [id])
  company Company @relation(fields: [company_id], references: [id])

  @@index([company_id, order_id, created_at])
}

model OrderFulfillment {
  id         String @id @default(cuid())
  company_id String
  order_id   String
  factory_id String
  product_id String

  quantity  Decimal @db.Decimal(15, 2)
  is_active Boolean @default(true)

  created_by String?
  created_at DateTime @default(now())

  company Company @relation(fields: [company_id], references: [id])
  order   Order   @relation(fields: [order_id], references: [id])
  factory Factory @relation(fields: [factory_id], references: [id])
  product Product @relation(fields: [product_id], references: [id])

  @@index([company_id, order_id])
  @@index([company_id, factory_id, created_at])
  @@index([company_id, factory_id, is_active, order_id])
  @@index([company_id, order_id, product_id])
}

//
// INVOICES (factory-scoped, can be generated from orders)
//

model Invoice {
  id         String @id @default(cuid())
  company_id String
  factory_id String
  client_id  String

  // Billing / legal entity used for this sale
  sales_company_id String?

  order_id             String? // generated from order if present
  reference_invoice_id String?
  invoice_no           String
  kind                 InvoiceKind @default(TAX_INVOICE)

  // Default: pending (unpaid). Proforma invoices use DRAFT explicitly in code.
  status InvoiceStatus @default(PENDING)

  issue_date DateTime  @default(now())
  due_date   DateTime?

  place_of_supply_state String?
  place_of_supply_code  String?
  supply_type           GstSupplyType?
  is_gst_invoice        Boolean        @default(true)

  subtotal      Decimal @default(0) @db.Decimal(15, 2)
  tax_subtotal  Decimal @default(0) @db.Decimal(15, 2)
  total_charges Decimal @default(0) @db.Decimal(15, 2)
  cgst_total    Decimal @default(0) @db.Decimal(15, 2)
  sgst_total    Decimal @default(0) @db.Decimal(15, 2)
  igst_total    Decimal @default(0) @db.Decimal(15, 2)
  cess_total    Decimal @default(0) @db.Decimal(15, 2)
  round_off     Decimal @default(0) @db.Decimal(15, 2)
  total         Decimal @default(0) @db.Decimal(15, 2)
  gst_breakup   Json?

  notes     String?
  is_active Boolean @default(true)

  created_by String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company           Company       @relation(fields: [company_id], references: [id])
  factory           Factory       @relation(fields: [factory_id], references: [id])
  client            Client        @relation(fields: [client_id], references: [id])
  order             Order?        @relation(fields: [order_id], references: [id])
  sales_company     SalesCompany? @relation(fields: [sales_company_id], references: [id])
  reference_invoice Invoice?      @relation("InvoiceReference", fields: [reference_invoice_id], references: [id])
  referenced_by     Invoice[]     @relation("InvoiceReference")

  items          InvoiceItem[]
  charges        InvoiceCharge[]
  status_history InvoiceStatusHistory[]
  allocations    PaymentAllocation[]

  @@unique([company_id, invoice_no])
  @@unique([company_id, order_id])
  @@index([company_id, factory_id, issue_date])
  @@index([company_id, factory_id, client_id, issue_date])
  @@index([company_id, status])
  @@index([company_id, is_active, issue_date])
  @@index([company_id, is_active, status, issue_date])
  @@index([company_id, order_id])
  @@index([company_id, reference_invoice_id])
}

model InvoiceItem {
  id         String @id @default(cuid())
  company_id String
  invoice_id String
  product_id String

  quantity      Decimal  @db.Decimal(15, 2)
  unit_price    Decimal  @db.Decimal(15, 2)
  discount      Decimal? @db.Decimal(15, 2)
  line_total    Decimal  @db.Decimal(15, 2)
  hsn_sac_code  String?
  gst_rate      Decimal? @db.Decimal(5, 2)
  cgst_rate     Decimal? @db.Decimal(5, 2)
  sgst_rate     Decimal? @db.Decimal(5, 2)
  igst_rate     Decimal? @db.Decimal(5, 2)
  cess_rate     Decimal? @db.Decimal(5, 2)
  taxable_value Decimal? @db.Decimal(15, 2)
  tax_amount    Decimal? @db.Decimal(15, 2)
  cgst_amount   Decimal? @db.Decimal(15, 2)
  sgst_amount   Decimal? @db.Decimal(15, 2)
  igst_amount   Decimal? @db.Decimal(15, 2)
  cess_amount   Decimal? @db.Decimal(15, 2)

  remarks String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  invoice Invoice @relation(fields: [invoice_id], references: [id])
  product Product @relation(fields: [product_id], references: [id])
  company Company @relation(fields: [company_id], references: [id])

  @@index([company_id, invoice_id])
  @@index([company_id, product_id])
}

model InvoiceCharge {
  id         String @id @default(cuid())
  company_id String
  invoice_id String

  type   ChargeType
  title  String
  amount Decimal    @db.Decimal(15, 2)
  meta   Json?

  created_at DateTime @default(now())

  invoice Invoice @relation(fields: [invoice_id], references: [id])
  company Company @relation(fields: [company_id], references: [id])

  @@index([company_id, invoice_id])
}

model InvoiceStatusHistory {
  id         String        @id @default(cuid())
  company_id String
  invoice_id String
  status     InvoiceStatus
  note       String?
  meta       Json?

  created_by String?
  created_at DateTime @default(now())

  invoice Invoice @relation(fields: [invoice_id], references: [id])
  company Company @relation(fields: [company_id], references: [id])

  @@index([company_id, invoice_id, created_at])
}

//
// PAYMENTS (append-only; partial payments supported by allocations)
//

model Payment {
  id         String  @id @default(cuid())
  company_id String
  factory_id String? // payment can be recorded at factory-level; keep optional for flexibility
  client_id  String

  // Link payment to a specific order (in addition to invoice allocations)
  order_id String?

  // Billing / legal entity used for this sale
  sales_company_id String?

  payment_no String?
  method     PaymentMethod
  status     PaymentStatus @default(RECORDED)

  amount  Decimal  @db.Decimal(15, 2)
  paid_at DateTime @default(now())

  reference String? // txn id / cheque no / etc
  remarks   String?
  meta      Json?

  created_by String?
  created_at DateTime @default(now())

  company       Company       @relation(fields: [company_id], references: [id])
  client        Client        @relation(fields: [client_id], references: [id])
  factory       Factory?      @relation(fields: [factory_id], references: [id])
  order         Order?        @relation(fields: [order_id], references: [id])
  sales_company SalesCompany? @relation(fields: [sales_company_id], references: [id])

  allocations PaymentAllocation[]

  @@index([company_id, client_id, paid_at])
  @@index([company_id, paid_at])
  @@index([company_id, factory_id, paid_at])
  @@index([company_id, order_id, paid_at])
  @@index([company_id, sales_company_id])
}

model PaymentAllocation {
  id         String @id @default(cuid())
  company_id String
  payment_id String
  invoice_id String

  amount Decimal @db.Decimal(15, 2)

  is_active Boolean @default(true)

  created_at DateTime @default(now())

  company Company @relation(fields: [company_id], references: [id])
  payment Payment @relation(fields: [payment_id], references: [id])
  invoice Invoice @relation(fields: [invoice_id], references: [id])

  @@unique([company_id, payment_id, invoice_id])
  @@index([company_id, payment_id])
  @@index([company_id, invoice_id])
}

//
// PURCHASE ORDERS (company purchases: raw materials, machinery, etc.)
//

model Purchase {
  id         String @id @default(cuid())
  company_id String
  factory_id String

  purchase_no   String
  status        PurchaseStatus @default(DRAFT)
  purchase_date DateTime       @default(now())

  vendor_name                  String
  vendor_gstin                 String?
  vendor_gst_registration_type GstRegistrationType?
  vendor_phone                 String?
  vendor_email                 String?
  vendor_address               String?
  vendor_state                 String?
  vendor_state_code            String?
  supply_type                  GstSupplyType?

  notes String?

  subtotal      Decimal @default(0) @db.Decimal(15, 2)
  tax_subtotal  Decimal @default(0) @db.Decimal(15, 2)
  total_charges Decimal @default(0) @db.Decimal(15, 2)
  cgst_total    Decimal @default(0) @db.Decimal(15, 2)
  sgst_total    Decimal @default(0) @db.Decimal(15, 2)
  igst_total    Decimal @default(0) @db.Decimal(15, 2)
  cess_total    Decimal @default(0) @db.Decimal(15, 2)
  round_off     Decimal @default(0) @db.Decimal(15, 2)
  total         Decimal @default(0) @db.Decimal(15, 2)
  gst_breakup   Json?

  is_active Boolean @default(true)

  created_by String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company Company @relation(fields: [company_id], references: [id])
  factory Factory @relation(fields: [factory_id], references: [id])

  items    PurchaseItem[]
  charges  PurchaseCharge[]
  timeline PurchaseStatusHistory[]
  receipts PurchaseReceipt[]
  returns  SupplierReturn[]

  @@unique([company_id, factory_id, purchase_no])
  @@index([company_id, factory_id, status])
  @@index([company_id, is_active, updated_at])
  @@index([company_id, factory_id, purchase_date])
}

model PurchaseItem {
  id          String  @id @default(cuid())
  company_id  String
  purchase_id String
  product_id  String?

  description       String
  unit              String?
  quantity          Decimal  @db.Decimal(15, 2)
  received_quantity Decimal  @default(0) @db.Decimal(15, 2)
  returned_quantity Decimal  @default(0) @db.Decimal(15, 2)
  unit_price        Decimal  @db.Decimal(15, 2)
  discount          Decimal? @db.Decimal(15, 2)
  line_total        Decimal  @db.Decimal(15, 2)
  hsn_sac_code      String?
  gst_rate          Decimal? @db.Decimal(5, 2)
  cgst_rate         Decimal? @db.Decimal(5, 2)
  sgst_rate         Decimal? @db.Decimal(5, 2)
  igst_rate         Decimal? @db.Decimal(5, 2)
  cess_rate         Decimal? @db.Decimal(5, 2)
  taxable_value     Decimal? @db.Decimal(15, 2)
  tax_amount        Decimal? @db.Decimal(15, 2)
  cgst_amount       Decimal? @db.Decimal(15, 2)
  sgst_amount       Decimal? @db.Decimal(15, 2)
  igst_amount       Decimal? @db.Decimal(15, 2)
  cess_amount       Decimal? @db.Decimal(15, 2)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company       Company               @relation(fields: [company_id], references: [id])
  purchase      Purchase              @relation(fields: [purchase_id], references: [id])
  product       Product?              @relation(fields: [product_id], references: [id])
  receipt_items PurchaseReceiptItem[]
  return_items  SupplierReturnItem[]

  @@index([company_id, purchase_id])
  @@index([company_id, product_id])
}

model PurchaseCharge {
  id          String @id @default(cuid())
  company_id  String
  purchase_id String

  type   ChargeType @default(OTHER)
  label  String
  amount Decimal    @db.Decimal(15, 2)
  meta   Json?

  created_at DateTime @default(now())

  company  Company  @relation(fields: [company_id], references: [id])
  purchase Purchase @relation(fields: [purchase_id], references: [id])

  @@index([company_id, purchase_id])
}

model PurchaseStatusHistory {
  id          String         @id @default(cuid())
  company_id  String
  purchase_id String
  status      PurchaseStatus
  note        String?

  created_by String?
  created_at DateTime @default(now())

  company  Company  @relation(fields: [company_id], references: [id])
  purchase Purchase @relation(fields: [purchase_id], references: [id])

  @@index([company_id, purchase_id])
  @@index([company_id, status])
}

//
// COMPLIANCE REPORTS (company-level, optionally factory-tagged)
//

model ComplianceReport {
  id         String    @id @default(cuid())
  company_id String
  factory_id String? // some certifications might be factory-specific
  title      String
  authority  String? // government/agency name
  valid_from DateTime?
  valid_to   DateTime?
  tags       String? // simple comma tags for filtering
  file_url   String // stored path / CDN url
  remarks    String?

  is_active Boolean @default(true)

  created_by String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company Company @relation(fields: [company_id], references: [id])

  @@index([company_id, factory_id, valid_to])
  @@index([company_id, is_active])
}

//
// MESSAGING (Email + WhatsApp via providers like Brevo + Meta)
//

model MessageTemplate {
  id         String @id @default(cuid())
  company_id String

  name    String
  channel MessageChannel
  subject String? // email only
  body    String // templated content (handle merge tags in code)
  meta    Json?

  is_active Boolean @default(true)

  created_by String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company         Company           @relation(fields: [company_id], references: [id])
  MessageCampaign MessageCampaign[]

  @@unique([company_id, name, channel])
  @@index([company_id, is_active])
}

model MessageCampaign {
  id         String         @id @default(cuid())
  company_id String
  factory_id String? // optional: campaign scoped to a factory view
  channel    MessageChannel

  name        String
  template_id String?
  purpose     String? // marketing / reminder / transactional / etc
  meta        Json?

  created_by String?
  created_at DateTime @default(now())

  company  Company          @relation(fields: [company_id], references: [id])
  template MessageTemplate? @relation(fields: [template_id], references: [id])

  recipients    MessageRecipient[]
  logs          MessageLog[]
  dispatch_jobs MessageDispatchJob[]

  @@index([company_id, factory_id, created_at])
  @@index([company_id, channel])
}

model MessageRecipient {
  id          String @id @default(cuid())
  company_id  String
  campaign_id String

  client_id  String?
  contact_id String?

  to_email String?
  to_phone String? // whatsapp

  payload    Json? // resolved merge variables snapshot (append-only trace)
  created_at DateTime @default(now())

  company  Company         @relation(fields: [company_id], references: [id])
  campaign MessageCampaign @relation(fields: [campaign_id], references: [id])

  @@index([company_id, campaign_id])
}

model MessageLog {
  id          String         @id @default(cuid())
  company_id  String
  campaign_id String?
  channel     MessageChannel

  // Links for traceability from anywhere (orders/invoices/etc)
  factory_id String?
  client_id  String?
  order_id   String?
  invoice_id String?

  to          String
  provider    String? // "brevo", "meta", etc
  provider_id String? // message id
  status      MessageStatus @default(QUEUED)
  error       String?

  payload    Json?
  created_by String?
  created_at DateTime @default(now())

  company           Company          @relation(fields: [company_id], references: [id])
  MessageCampaign   MessageCampaign? @relation(fields: [messageCampaignId], references: [id])
  messageCampaignId String?

  @@index([company_id, channel, created_at])
  @@index([company_id, status, created_at])
  @@index([company_id, client_id, created_at])
  @@index([company_id, order_id])
  @@index([company_id, invoice_id])
}

// ------------------------------------------------------------
model MessageDispatchJob {
  id          String            @id @default(cuid())
  company_id  String
  campaign_id String
  status      DispatchJobStatus @default(QUEUED)

  created_by  String?
  created_at  DateTime  @default(now())
  started_at  DateTime?
  finished_at DateTime?

  total_recipients Int @default(0)
  processed_count  Int @default(0)
  sent_count       Int @default(0)
  failed_count     Int @default(0)

  error String?

  company  Company         @relation(fields: [company_id], references: [id])
  campaign MessageCampaign @relation(fields: [campaign_id], references: [id])

  @@index([company_id, status, created_at])
  @@index([company_id, campaign_id, created_at])
}

// Internal realtime messaging (Socket.IO) + REST initial load
// ------------------------------------------------------------

enum ConversationType {
  DIRECT
}

model Conversation {
  id         String           @id @default(cuid())
  company_id String
  type       ConversationType @default(DIRECT)

  // Prevent duplicate 1:1 conversations.
  // For DIRECT: direct_key = "<minUserId>:<maxUserId>"
  direct_key String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company  Company              @relation(fields: [company_id], references: [id])
  members  ConversationMember[]
  messages ChatMessage[]

  @@unique([company_id, direct_key])
  @@index([company_id, created_at])
  @@index([company_id, updated_at])
}

model ConversationMember {
  id              String @id @default(cuid())
  company_id      String
  conversation_id String
  user_id         String

  last_read_at DateTime?

  created_at DateTime @default(now())

  company      Company      @relation(fields: [company_id], references: [id])
  conversation Conversation @relation(fields: [conversation_id], references: [id])
  user         User         @relation(fields: [user_id], references: [id])

  @@unique([conversation_id, user_id])
  @@index([company_id, user_id])
  @@index([company_id, conversation_id])
}

model ChatMessage {
  id              String @id @default(cuid())
  company_id      String
  conversation_id String
  sender_id       String
  body            String

  created_at DateTime @default(now())

  company      Company      @relation(fields: [company_id], references: [id])
  conversation Conversation @relation(fields: [conversation_id], references: [id])
  sender       User         @relation("ChatMessageSender", fields: [sender_id], references: [id])

  @@index([company_id, created_at])
  @@index([conversation_id, created_at])
}

enum BroadcastTargetType {
  ALL
  ROLES
  USERS
}

model BroadcastMessage {
  id          String              @id @default(cuid())
  company_id  String
  sender_id   String
  body        String
  target_type BroadcastTargetType

  // Snapshot of target ids used at send-time
  target_role_ids String[] @default([])
  target_user_ids String[] @default([])

  created_at DateTime @default(now())

  company    Company              @relation(fields: [company_id], references: [id])
  sender     User                 @relation("BroadcastSender", fields: [sender_id], references: [id])
  recipients BroadcastRecipient[]

  @@index([company_id, created_at])
}

model BroadcastRecipient {
  id           String @id @default(cuid())
  company_id   String
  broadcast_id String
  user_id      String

  seen_at    DateTime?
  created_at DateTime  @default(now())

  company   Company          @relation(fields: [company_id], references: [id])
  broadcast BroadcastMessage @relation(fields: [broadcast_id], references: [id])
  user      User             @relation(fields: [user_id], references: [id])

  @@unique([broadcast_id, user_id])
  @@index([company_id, created_at])
  @@index([user_id, seen_at])
  @@index([company_id, broadcast_id])
}

model TaxClass {
  id          String   @id @default(cuid())
  company_id  String
  name        String
  description String?
  gst_rate    Decimal  @db.Decimal(5, 2)
  cess_rate   Decimal  @default(0) @db.Decimal(5, 2)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  company  Company   @relation(fields: [company_id], references: [id])
  products Product[]

  @@unique([company_id, name])
  @@index([company_id, is_active])
}

model ProductBarcode {
  id         String   @id @default(cuid())
  company_id String
  product_id String
  code       String
  alias_type String? // PRIMARY / PACK / INTERNAL / SUPPLIER
  is_primary Boolean  @default(false)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company Company @relation(fields: [company_id], references: [id])
  product Product @relation(fields: [product_id], references: [id])

  @@unique([company_id, code])
  @@index([company_id, product_id, is_active])
}

model InventoryBatch {
  id               String    @id @default(cuid())
  company_id       String
  factory_id       String
  product_id       String
  batch_no         String
  expiry_date      DateTime?
  manufacture_date DateTime?
  barcode          String?
  location_label   String?
  notes            String?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  company            Company                     @relation(fields: [company_id], references: [id])
  factory            Factory                     @relation(fields: [factory_id], references: [id])
  product            Product                     @relation(fields: [product_id], references: [id])
  serials            InventorySerial[]
  tracking_balances  InventoryTrackingBalance[]
  movement_trackings InventoryMovementTracking[]

  @@unique([company_id, factory_id, product_id, batch_no])
  @@index([company_id, product_id, expiry_date])
  @@index([company_id, factory_id, location_label])
}

model InventorySerial {
  id               String       @id @default(cuid())
  company_id       String
  factory_id       String
  product_id       String
  batch_id         String?
  serial_no        String
  barcode          String?
  expiry_date      DateTime?
  location_label   String?
  status           SerialStatus @default(IN_STOCK)
  last_movement_id String?
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  company            Company                     @relation(fields: [company_id], references: [id])
  factory            Factory                     @relation(fields: [factory_id], references: [id])
  product            Product                     @relation(fields: [product_id], references: [id])
  batch              InventoryBatch?             @relation(fields: [batch_id], references: [id])
  tracking_balances  InventoryTrackingBalance[]
  movement_trackings InventoryMovementTracking[]

  @@unique([company_id, serial_no])
  @@index([company_id, product_id, status])
  @@index([company_id, factory_id, location_label])
}

model InventoryMovementTracking {
  id             String    @id @default(cuid())
  company_id     String
  factory_id     String
  product_id     String
  movement_id    String
  batch_id       String?
  serial_id      String?
  barcode        String?
  expiry_date    DateTime?
  location_label String?
  quantity       Decimal   @db.Decimal(15, 2)
  created_at     DateTime  @default(now())

  company  Company           @relation(fields: [company_id], references: [id])
  factory  Factory           @relation(fields: [factory_id], references: [id])
  product  Product           @relation(fields: [product_id], references: [id])
  movement InventoryMovement @relation(fields: [movement_id], references: [id])
  batch    InventoryBatch?   @relation(fields: [batch_id], references: [id])
  serial   InventorySerial?  @relation(fields: [serial_id], references: [id])

  @@index([company_id, movement_id])
  @@index([company_id, product_id, batch_id])
  @@index([company_id, product_id, serial_id])
}

model InventoryTrackingBalance {
  id             String    @id @default(cuid())
  company_id     String
  factory_id     String
  product_id     String
  batch_id       String?
  serial_id      String?
  barcode        String?
  expiry_date    DateTime?
  location_label String?
  quantity       Decimal   @default(0) @db.Decimal(15, 2)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  company Company          @relation(fields: [company_id], references: [id])
  factory Factory          @relation(fields: [factory_id], references: [id])
  product Product          @relation(fields: [product_id], references: [id])
  batch   InventoryBatch?  @relation(fields: [batch_id], references: [id])
  serial  InventorySerial? @relation(fields: [serial_id], references: [id])

  @@unique([company_id, factory_id, product_id, batch_id, serial_id, barcode, location_label])
  @@index([company_id, product_id, expiry_date])
  @@index([company_id, factory_id, location_label])
}

model DeliveryChallan {
  id                    String                @id @default(cuid())
  company_id            String
  factory_id            String
  client_id             String?
  order_id              String?
  sales_company_id      String?
  challan_no            String
  kind                  DeliveryChallanKind   @default(OUTWARD)
  reason                DeliveryChallanReason @default(SALE)
  status                DeliveryChallanStatus @default(DRAFT)
  issue_date            DateTime              @default(now())
  place_of_supply_state String?
  place_of_supply_code  String?
  notes                 String?
  is_active             Boolean               @default(true)
  created_by            String?
  created_at            DateTime              @default(now())
  updated_at            DateTime              @updatedAt

  company       Company               @relation(fields: [company_id], references: [id])
  factory       Factory               @relation(fields: [factory_id], references: [id])
  client        Client?               @relation(fields: [client_id], references: [id])
  order         Order?                @relation(fields: [order_id], references: [id])
  sales_company SalesCompany?         @relation(fields: [sales_company_id], references: [id])
  items         DeliveryChallanItem[]

  @@unique([company_id, challan_no])
  @@index([company_id, factory_id, issue_date])
  @@index([company_id, status])
}

model DeliveryChallanItem {
  id                  String   @id @default(cuid())
  company_id          String
  delivery_challan_id String
  product_id          String
  quantity            Decimal  @db.Decimal(15, 2)
  remarks             String?
  created_at          DateTime @default(now())

  company          Company         @relation(fields: [company_id], references: [id])
  delivery_challan DeliveryChallan @relation(fields: [delivery_challan_id], references: [id])
  product          Product         @relation(fields: [product_id], references: [id])

  @@index([company_id, delivery_challan_id])
  @@index([company_id, product_id])
}

model PurchaseReceipt {
  id           String                @id @default(cuid())
  company_id   String
  factory_id   String
  purchase_id  String
  receipt_no   String
  status       PurchaseReceiptStatus @default(DRAFT)
  receipt_date DateTime              @default(now())
  notes        String?
  created_by   String?
  created_at   DateTime              @default(now())
  updated_at   DateTime              @updatedAt

  company  Company               @relation(fields: [company_id], references: [id])
  factory  Factory               @relation(fields: [factory_id], references: [id])
  purchase Purchase              @relation(fields: [purchase_id], references: [id])
  items    PurchaseReceiptItem[]

  @@unique([company_id, receipt_no])
  @@index([company_id, purchase_id, receipt_date])
}

model PurchaseReceiptItem {
  id                    String   @id @default(cuid())
  company_id            String
  purchase_receipt_id   String
  purchase_item_id      String?
  product_id            String?
  inventory_movement_id String?
  description           String
  ordered_quantity      Decimal? @db.Decimal(15, 2)
  quantity              Decimal  @db.Decimal(15, 2)
  accepted_quantity     Decimal  @db.Decimal(15, 2)
  rejected_quantity     Decimal  @default(0) @db.Decimal(15, 2)
  unit_cost             Decimal? @db.Decimal(15, 2)
  location_label        String?
  notes                 String?
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  company          Company         @relation(fields: [company_id], references: [id])
  purchase_receipt PurchaseReceipt @relation(fields: [purchase_receipt_id], references: [id])
  purchase_item    PurchaseItem?   @relation(fields: [purchase_item_id], references: [id])
  product          Product?        @relation(fields: [product_id], references: [id])

  @@index([company_id, purchase_receipt_id])
  @@index([company_id, purchase_item_id])
  @@index([company_id, product_id])
}

model SupplierReturn {
  id             String               @id @default(cuid())
  company_id     String
  factory_id     String
  purchase_id    String
  return_no      String
  debit_note_no  String?
  status         SupplierReturnStatus @default(DRAFT)
  return_date    DateTime             @default(now())
  reason_summary String?
  notes          String?
  created_by     String?
  created_at     DateTime             @default(now())
  updated_at     DateTime             @updatedAt

  company  Company              @relation(fields: [company_id], references: [id])
  factory  Factory              @relation(fields: [factory_id], references: [id])
  purchase Purchase             @relation(fields: [purchase_id], references: [id])
  items    SupplierReturnItem[]

  @@unique([company_id, return_no])
  @@index([company_id, purchase_id, return_date])
}

model SupplierReturnItem {
  id                    String   @id @default(cuid())
  company_id            String
  supplier_return_id    String
  purchase_item_id      String?
  product_id            String?
  inventory_movement_id String?
  description           String
  quantity              Decimal  @db.Decimal(15, 2)
  unit_price            Decimal? @db.Decimal(15, 2)
  reason_code           String?
  reason_note           String?
  location_label        String?
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  company         Company        @relation(fields: [company_id], references: [id])
  supplier_return SupplierReturn @relation(fields: [supplier_return_id], references: [id])
  purchase_item   PurchaseItem?  @relation(fields: [purchase_item_id], references: [id])
  product         Product?       @relation(fields: [product_id], references: [id])

  @@index([company_id, supplier_return_id])
  @@index([company_id, purchase_item_id])
  @@index([company_id, product_id])
}

model CompanyPlatformConfig {
  id                      String    @id @default(cuid())
  company_id              String    @unique
  tenant_slug             String?   @unique
  app_title               String?
  theme_color             String?
  logo_url                String?
  locale                  String?
  timezone                String?
  invoice_header          String?
  invoice_footer          String?
  plan_code               String?
  billing_cycle           String?
  subscription_status     String?
  trial_ends_at           DateTime?
  active_until            DateTime?
  platform_last_synced_at DateTime?
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  company Company @relation(fields: [company_id], references: [id])

  @@index([subscription_status])
}
