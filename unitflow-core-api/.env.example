# UnitFlow Core API
NODE_ENV=development
SERVICE_NAME=unitflow-core-api
APP_NAME=UnitFlow
PORT=4000
RUNTIME_MODE=saas-shared
API_CLIENT_MODE=electron-shell-over-api
VALIDATE_ENV_ON_BOOT=true

# Database / auth
DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_SECRET=replace-with-a-32-char-minimum-secret
JWT_EXPIRES_IN=12h
SESSION_TOUCH_INTERVAL_MS=60000
ROLE_CACHE_TTL_MS=30000

# Request handling / logging
JSON_BODY_LIMIT=5mb
LOG_LEVEL=debug
LOG_ALL_REQUESTS=false
SLOW_REQUEST_MS=750
REQUEST_ID_HEADER=x-request-id
ACTIVITY_LOG_ENABLED=true

# CORS
# Comma-separated exact origins, e.g. https://app.unitflow.com,http://localhost:3000
CORS_ALLOWED_ORIGINS=
# Comma-separated regexes, e.g. ^https://.*\\.unitflow\\.com$
CORS_ALLOWED_ORIGIN_REGEXES=
CORS_ALLOW_NO_ORIGIN=true
TRUST_PROXY=1

# Rate limiting / idempotency
RATE_LIMIT_MAX_PER_MIN=300
AUTH_RATE_LIMIT_MAX_PER_15_MIN=50
IDEMPOTENCY_ENABLED=true
IDEMPOTENCY_TTL_SECONDS=43200

# Compression
COMPRESSION_THRESHOLD_BYTES=1024

# Redis (optional)
REDIS_URL=
REDIS_RATE_LIMIT_ENABLED=false
REDIS_SOCKET_IO_ENABLED=false

# PDF branding
INVOICE_LOGO_PATH=
PDF_THEME_COLOR=#1F6FEB

# Email / password reset
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=
PASSWORD_RESET_OTP_EXPIRES_MINUTES=10
PASSWORD_RESET_OTP_COOLDOWN_SECONDS=60
PASSWORD_RESET_OTP_MAX_ATTEMPTS=5

# WhatsApp / messaging
META_WA_ACCESS_TOKEN=
META_WA_PHONE_NUMBER_ID=
META_WA_VERSION=v20.0
MESSAGE_SEND_RATE_PER_SEC=3
MESSAGE_MAX_PER_CAMPAIGN_RUN=500
MESSAGE_QUEUE_POLL_MS=5000

# Branding
BRAND_NAME=UnitFlow
BRAND_ADDRESS=
PDF_BRAND_NAME=UnitFlow
PDF_BRAND_ADDRESS=
BREVO_SENDER_NAME=UnitFlow

# Platform integration
PLATFORM_INTERNAL_API_KEY=replace-with-a-long-shared-secret-between-platform-and-core

# Runtime auth boundary
ALLOW_DIRECT_CORE_LOGIN=true
PLATFORM_RUNTIME_JWT_SECRET=replace-with-a-shared-runtime-jwt-secret
PLATFORM_RUNTIME_JWT_ISSUER=unitflow-platform-api
PLATFORM_RUNTIME_JWT_AUDIENCE=unitflow-core-api