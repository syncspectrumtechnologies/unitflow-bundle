NODE_ENV=development
PORT=4100
SERVICE_NAME=unitflow-platform-api
APP_NAME=UnitFlow Platform
PLATFORM_DATABASE_URL=postgresql://neondb_owner:npg_Ihd4yFVl0vNO@ep-cool-pond-a1p4m0e7.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
JWT_SECRET=replace-with-a-32-char-minimum-secret
JWT_EXPIRES_IN=12h
OPS_JWT_SECRET=replace-with-a-second-32-char-minimum-secret
OPS_JWT_EXPIRES_IN=12h
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:3001
CORS_ALLOW_NO_ORIGIN=true
TRUST_PROXY=1
JSON_BODY_LIMIT=3mb
LOG_LEVEL=debug
RATE_LIMIT_MAX_PER_MIN=300
AUTH_RATE_LIMIT_MAX_PER_15_MIN=50
REQUEST_ID_HEADER=x-request-id
VALIDATE_ENV_ON_BOOT=true

# Paid plans
DEFAULT_SINGLE_USER_MONTHLY_PRICE_MINOR=99900
DEFAULT_SINGLE_USER_YEARLY_PRICE_MINOR=999900
DEFAULT_MULTI_USER_MONTHLY_PRICE_MINOR=299900
DEFAULT_MULTI_USER_YEARLY_PRICE_MINOR=2999900
DEFAULT_MULTI_USER_SEAT_LIMIT=5
DEFAULT_CURRENCY=INR
PROVISIONING_WORKER_ENABLED=true
PROVISIONING_WORKER_INTERVAL_MS=5000
PROVISIONING_WORKER_BATCH_SIZE=5

# Core API integration
CORE_API_BASE_URL=http://localhost:4000
PLATFORM_INTERNAL_API_KEY=replace-with-a-long-shared-secret-between-platform-and-core

# Verification / notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=no-reply@unitflow.local
SMTP_FROM_NAME=UnitFlow
VERIFICATION_CODE_TTL_MINUTES=15
PAYMENT_WEBHOOK_SECRET=replace-with-payment-webhook-secret

BOOTSTRAP_OPS_EMAIL=ops@unitflow.local
BOOTSTRAP_OPS_NAME=UnitFlow Ops Admin
BOOTSTRAP_OPS_PASSWORD=StrongPassword@123

# Shared runtime JWT (Platform signs, Core verifies)
PLATFORM_RUNTIME_JWT_SECRET=replace-with-a-shared-runtime-jwt-secret
PLATFORM_RUNTIME_JWT_ISSUER=unitflow-platform-api
PLATFORM_RUNTIME_JWT_AUDIENCE=unitflow-core-api
RUNTIME_JWT_EXPIRES_IN=12h

# Optional: bootstrap a privileged platform super admin on boot
BOOTSTRAP_SUPER_ADMIN_EMAIL=jadusingh69@gmail.com
BOOTSTRAP_SUPER_ADMIN_PASSWORD=Password@123
BOOTSTRAP_SUPER_ADMIN_NAME= Jadu Singh
BOOTSTRAP_SUPER_ADMIN_PHONE=6969666969
